                <div style="display: flex; gap: 20px; justify-content: center; margin-bottom: 30px; background: #F3EFE0; padding: 15px; border-radius: 12px; border: 1px solid #E6E1D3;">
                    <label style="font-size: 0.85rem; color: #000; cursor: pointer; display: flex; align-items: center; gap: 5px;"><input type="radio" name="add-category" value="MANAGED" checked> 愿?由щ???긽</label>
                    <label style="font-size: 0.85rem; color: #000; cursor: pointer; display: flex; align-items: center; gap: 5px;"><input type="radio" name="add-category" value="SANDBOX"> ?깒?뱶諛뺤뒪</label>
                    <label style="font-size: 0.85rem; color: #000; cursor: pointer; display: flex; align-items: center; gap: 5px;"><input type="radio" name="add-category" value="GENERAL"> ?씪諛섎???긽</label>
                </div>
                <div style="display: flex; gap: 15px;">
                    <button type="button" class="btn btn-outline" style="flex:1; border-color: #cbd5e1; color: #64748b; background: transparent;" onclick="closeCorpAddModal()">痍⑥냼</button>
                    <button type="button" class="btn btn-primary" style="flex:1; background: #4A4A4A; color: #fff; border: none; box-shadow: 2px 2px 5px rgba(0,0,0,0.2); font-weight: 700;" onclick="saveNewCompany()">????옣</button>
                </div>
