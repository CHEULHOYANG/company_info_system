            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px;" id="stats-grid">
                <div class="card" style="padding:25px; text-align:center; margin-bottom:0;">
                    <div style="font-family:'Orbitron',sans-serif; font-size:0.65rem; color:var(--neon-cyan); letter-spacing:2px; margin-bottom:10px;">珥? 諛쒖넚 諛곗튂</div>
                    <div id="stat-total-batches" style="font-size:2.2rem; font-weight:900; color:#fff;">-</div>
                </div>
                <div class="card" style="padding:25px; text-align:center; margin-bottom:0; border-color:rgba(0,255,204,0.3);">
                    <div style="font-family:'Orbitron',sans-serif; font-size:0.65rem; color:var(--neon-cyan); letter-spacing:2px; margin-bottom:10px;">珥? 諛쒖넚 嫄댁닔</div>
                    <div id="stat-total-sent" style="font-size:2.2rem; font-weight:900; color:var(--neon-cyan);">-</div>
                </div>
                <div class="card" style="padding:25px; text-align:center; margin-bottom:0; border-color:rgba(0,255,204,0.2);">
                    <div style="font-family:'Orbitron',sans-serif; font-size:0.65rem; color:#4ade80; letter-spacing:2px; margin-bottom:10px;">?꽦怨?</div>
                    <div id="stat-total-success" style="font-size:2.2rem; font-weight:900; color:#4ade80;">-</div>
                </div>
                <div class="card" style="padding:25px; text-align:center; margin-bottom:0; border-color:rgba(255,49,205,0.2);">
                    <div style="font-family:'Orbitron',sans-serif; font-size:0.65rem; color:var(--neon-purple); letter-spacing:2px; margin-bottom:10px;">?떎?뙣</div>
                    <div id="stat-total-fail" style="font-size:2.2rem; font-weight:900; color:var(--neon-purple);">-</div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h2 class="card-title"><i class="fas fa-chart-bar" style="margin-right:10px;"></i>諛곗튂蹂? 諛쒖넚 ?쁽?솴</h2>
                    <button class="btn btn-outline" onclick="loadDispatchStats()" style="padding:8px 16px; font-size:0.75rem;">
                        <i class="fas fa-sync-alt"></i> ?깉濡쒓퀬移?
                    </button>
                </div>

                <div style="overflow-x: auto;">
                <!-- ?윍? 諛쒖넚 ?쁽?솴 寃??깋諛? -->
                <div style="display: flex; gap: 12px; padding: 20px; background: rgba(255,255,255,0.02); border-radius: 12px; margin-bottom: 20px; align-items: flex-end; flex-wrap: wrap;">
                    <div style="flex: 2; min-width: 200px;">
                        <label style="font-size: 0.7rem; color: var(--text-secondary); margin-bottom: 5px; display: block;">諛곗튂 ID ?삉?뒗 ?젣紐? 寃??깋</label>
                        <input type="text" id="search-result-key" placeholder="議고쉶 ?궎?썙?뱶 ?엯?젰..." onkeyup="if(event.key==='Enter') filterResultTable()" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #fff; padding: 10px; width: 100%; font-size: 0.85rem;">
                    </div>
                    <div style="flex: 1; min-width: 150px;">
                        <label style="font-size: 0.7rem; color: var(--text-secondary); margin-bottom: 5px; display: block;">諛쒖넚 ?씪?옄</label>
                        <input type="date" id="search-result-date" onchange="filterResultTable()" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #fff; padding: 9px; width: 100%; font-size: 0.85rem;">
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <button class="btn btn-primary" onclick="filterResultTable()" style="padding: 10px 20px; font-size: 0.8rem; box-shadow: 0 0 15px rgba(0, 212, 255, 0.3);">
                            <i class="fas fa-search"></i> 寃??깋
                        </button>
                        <button class="btn btn-outline" onclick="resetResultFilter()" style="padding: 10px 15px; font-size: 0.8rem; border-color: rgba(255,255,255,0.1); color: var(--text-secondary);">
                            <i class="fas fa-undo"></i>
                        </button>
                    </div>
                    <div style="flex-grow: 1; text-align: right;">
