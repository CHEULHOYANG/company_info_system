    <!-- Modals (Add, Edit, SMTP, Progress) -->
    <div id="progress-overlay" class="progress-overlay">
        <div class="progress-card">
            <div class="gauge-container">
                <div class="quantum-ring"></div>
                <svg class="gauge-svg" viewBox="0 0 240 240">
                    <defs>
                        <linearGradient id="quantum-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#00f2ff; stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#7000ff; stop-opacity:1" />
                        </linearGradient>
                    </defs>
                    <circle class="gauge-bg" cx="120" cy="120" r="100"></circle>
                    <circle id="gauge-progress" class="gauge-fill" cx="120" cy="120" r="100" stroke-dasharray="628" style="--gauge-percent: 0;"></circle>
                </svg>
                <div class="quantum-core">
                    <div id="gauge-percent" class="gauge-percentage">0%</div>
                    <div style="font-size: 0.6rem; color: var(--neon-cyan); letter-spacing: 2px; font-family: 'Orbitron';">QUANTUM SYNC</div>
                </div>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
                <div class="stat-mini" style="background: rgba(0, 255, 204, 0.05); border-color: var(--neon-cyan);">
                    <span class="label" style="color: var(--neon-cyan);">?꽦怨?</span>
                    <span id="progress-success" class="value" style="color: #fff;">0</span>
                </div>
                <div class="stat-mini" style="background: rgba(255, 49, 205, 0.05); border-color: var(--neon-purple);">
                    <span class="label" style="color: var(--neon-purple);">?떎?뙣</span>
                    <span id="progress-fail" class="value" style="color: #fff;">0</span>
                </div>
            </div>
            <p id="progress-summary" style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 30px;"></p>
            <button id="btn-progress-close" class="btn btn-primary" style="width: 100%; display: none;" onclick="document.getElementById('progress-overlay').style.display='none'">紐⑤땲?꽣留? 醫낅즺</button>
        </div>
    </div>

