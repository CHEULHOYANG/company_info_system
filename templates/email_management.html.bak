                    <select id="add-region" class="form-control" style="background: #fff; color: #000 !important; border: 1px solid #D1CBB5; height: 48px; font-size: 0.85rem; appearance: auto !important; padding: 5px 10px;">
                        <option value="?꽌?슱">?꽌?슱 (SEOUL)</option><option value="寃쎄린">寃쎄린 (GYEONGGI)</option><option value="?씤泥?">?씤泥? (INCHEON)</option><option value="媛뺤썝">媛뺤썝</option><option value="異⑸턿">異⑸턿</option><option value="異⑸궓">異⑸궓</option><option value="?쟾遺?">?쟾遺?</option><option value="?쟾?궓">?쟾?궓</option><option value="寃쎈턿">寃쎈턿</option><option value="寃쎈궓">寃쎈궓</option><option value="?젣二?">?젣二?</option>
                    </select>
