    <!-- Corp Edit Modal -->
    <div id="corp-edit-modal" class="modal-overlay">
        <div class="modal-card" style="background: #ffffff !important; color: #000000 !important; border: 1px solid rgba(0,0,0,0.1); box-shadow: 0 20px 50px rgba(0,0,0,0.2);">
            <h2 class="card-title" style="margin-bottom: 30px; color: #000000 !important; border-bottom: 2px solid #00d4ff; padding-bottom: 10px;"><i class="fas fa-edit"></i> 湲곗뾽 ?젙蹂? 怨좊룄?솕</h2>
            <form id="corp-edit-form">
                <input type="hidden" id="edit-biz-no">
                <div style="margin-bottom: 20px;">
                    <label style="font-size: 0.75rem; color: #64748b; display: block; margin-bottom: 8px;">湲곗뾽 紐낆묶</label>
                    <input type="text" id="edit-company-name" class="form-control" style="background: #f8fafc; color: #000 !important; border: 1px solid #e2e8f0;">
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="font-size: 0.75rem; color: #64748b; display: block; margin-bottom: 8px;">?씠硫붿씪 二쇱냼 (?씠硫붿씪 ?벑濡?/?닔?젙 媛??뒫)</label>
                    <input type="email" id="edit-email" class="form-control" placeholder="example@domain.com" style="background: #f8fafc; color: #000 !important; border: 1px solid #e2e8f0;">
                </div>
                <div style="margin-bottom: 35px;">
                    <label style="font-size: 0.75rem; color: #64748b; display: block; margin-bottom: 12px;">?슫?쁺 遺꾨쪟 ?꽕?젙 (?깒?뱶諛뺤뒪/愿?由щ???긽 ?쟾?솚 媛??뒫)</label>
                    <div style="display: flex; gap: 15px; justify-content: center; background: #f1f5f9; padding: 15px; border-radius: 14px; color: #000;">
                        <label style="font-size: 0.85rem; cursor: pointer;"><input type="radio" name="edit-category" value="MANAGED"> 愿?由щ???긽</label>
                        <label style="font-size: 0.85rem; cursor: pointer;"><input type="radio" name="edit-category" value="SANDBOX"> ?깒?뱶諛뺤뒪</label>
                        <label style="font-size: 0.85rem; cursor: pointer;"><input type="radio" name="edit-category" value="GENERAL"> ?씪諛섎???긽</label>
                    </div>
                </div>
                <div style="display: flex; gap: 15px;">
                    <button type="button" class="btn btn-outline" style="flex:1; border-color: #cbd5e1; color: #64748b;" onclick="document.getElementById('corp-edit-modal').style.display='none'">痍⑥냼</button>
                    <button type="button" class="btn btn-primary" style="flex:1;" onclick="saveEditCompany()">蹂?寃? ?궗?빆 ?쟻?슜</button>
                </div>
            </form>
        </div>
    </div>

    <!-- SMTP Modal -->
    <div id="smtp-modal" class="modal-overlay">
        <div class="modal-card" style="background: #FDFAF0 !important; color: #000000 !important; border: 1px solid #E6E1D3; box-shadow: 0 20px 60px rgba(0,0,0,0.3);">
            <h2 class="card-title" style="margin-bottom: 30px; color: #000000 !important; border-bottom: 2px solid #00d4ff; padding-bottom: 10px;"><i class="fas fa-server"></i> SMTP 由대젅?씠 援ъ꽦</h2>
            <form id="smtp-form">
                <input type="hidden" id="smtp-id">
                <select id="smtp-provider" class="form-control" style="margin-bottom: 15px; background: #fff; color: #000 !important; border: 1px solid #D1CBB5; height: 48px; font-size: 0.85rem; appearance: auto !important; padding: 5px 10px;" onchange="handleSmtpProviderChange()">
                    <option value="">-- ?쎒硫붿씪 ?꽌鍮꾩뒪 ?꽑?깮 (?꽑?깮 ?떆 ?옄?룞?엯?젰) --</option>
                    <option value="naver">?꽕?씠踰? (Naver)</option>
                    <option value="gmail">援ш?? (Gmail)</option>
                    <option value="kakao">移댁뭅?삤 (Kakao/Daum)</option>
                    <option value="hanmail">?븳硫붿씪 (Hanmail)</option>
                    <option value="nate">?꽕?씠?듃 (Nate)</option>
                    <option value="custom">吏곸젒 ?엯?젰 (Custom)</option>
                </select>
                <input type="text" id="smtp-name" class="form-control" placeholder="愿?由? 紐낆묶 (?삁: ?꽕?씠踰? 二쇰젰 ?꽌踰?)" style="margin-bottom: 15px; background: #fff; color: #000 !important; border: 1px solid #D1CBB5; height: 48px; font-size: 0.85rem;">
                <input type="text" id="smtp-server" class="form-control" placeholder="SMTP ?샇?뒪?듃 (e.g. smtp.naver.com)" style="margin-bottom: 15px; background: #fff; color: #000 !important; border: 1px solid #D1CBB5; height: 48px; font-size: 0.85rem;">
                <input type="number" id="smtp-port" class="form-control" placeholder="?룷?듃踰덊샇" value="465" style="margin-bottom: 15px; background: #fff; color: #000 !important; border: 1px solid #D1CBB5; height: 48px; font-size: 0.85rem;">
                <input type="text" id="smtp-email" class="form-control" placeholder="?씤利? ?씠硫붿씪 怨꾩젙" style="margin-bottom: 15px; background: #fff; color: #000 !important; border: 1px solid #D1CBB5; height: 48px; font-size: 0.85rem;">
                <input type="password" id="smtp-password" class="form-control" placeholder="?씤利? 鍮꾨??踰덊샇" style="margin-bottom: 30px; background: #fff; color: #000 !important; border: 1px solid #D1CBB5; height: 48px; font-size: 0.85rem;">
                <div style="display: flex; gap: 15px;">
                    <button type="button" class="btn btn-outline" style="flex:1; border-color: #cbd5e1; color: #64748b; background: transparent;" onclick="closeSmtpModal()">痍⑥냼</button>
                    <button type="button" class="btn btn-primary" style="flex:1; background: #4A4A4A; color: #fff; border: none; box-shadow: 2px 2px 5px rgba(0,0,0,0.2);" onclick="saveSmtpConfig()">?끂?뱶 ?솢?꽦?솕</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // High-Vibrancy Space Engine
        (function() {
            const canvas = document.getElementById('particle-canvas');
            const ctx = canvas.getContext('2d');
            let w, h, particles = [];

            function init() {
                w = canvas.width = window.innerWidth;
                h = canvas.height = window.innerHeight;
                particles = [];
                for(let i=0; i<180; i++) particles.push(new Particle('star'));
                for(let i=0; i<30; i++) particles.push(new Particle('asteroid'));
            }

            class Particle {
                constructor(type) { this.type = type; this.reset(); }
                reset() {
                    this.x = Math.random() * w; this.y = Math.random() * h;
                    this.r = this.type === 'star' ? Math.random() * 1.5 + 0.3 : Math.random() * 4 + 1;
                    // Asteroids move mostly right (positive speedX)
                    this.speedX = this.type === 'star' ? (Math.random() - 0.5) * 0.1 : (Math.random() * 0.5 + 0.4); 
                    this.speedY = this.type === 'star' ? Math.random() * 0.2 + 0.1 : (Math.random() * 0.3 - 0.15);
                    this.opacity = Math.random() * 0.7 + 0.2;
                    this.color = this.type === 'star' ? '#ffffff' : '#64748b';
                    this.rotation = Math.random() * Math.PI * 2;
                    this.rotationSpeed = (Math.random() - 0.5) * 0.04;
                    this.pulse = Math.random() * Math.PI;
                    this.pulseSpeed = Math.random() * 0.04 + 0.01;
                }
                update() {
                    this.x += this.speedX; this.y -= this.speedY;
                    this.rotation += this.rotationSpeed; this.pulse += this.pulseSpeed;
                    if (this.y < -20) this.y = h + 20; if (this.x > w + 20) this.x = -20;
                    if (this.x < -20) this.x = w + 20; if (this.y > h + 20) this.y = -20;
                }
                draw() {
                    ctx.save(); ctx.translate(this.x, this.y); ctx.rotate(this.rotation);
                    let drawOpacity = this.opacity * (this.type === 'star' ? (Math.sin(this.pulse) * 0.4 + 0.6) : 1);
                    ctx.beginPath();
                    if(this.type === 'asteroid') {
                        ctx.moveTo(0, -this.r); ctx.lineTo(this.r, -this.r*0.4); ctx.lineTo(this.r*0.7, this.r*0.7); ctx.lineTo(-this.r*0.6, this.r); ctx.lineTo(-this.r, 0);
                    } else { ctx.arc(0, 0, this.r, 0, Math.PI * 2); }
                    ctx.fillStyle = this.color; ctx.globalAlpha = drawOpacity; ctx.fill();
                    ctx.restore();
                }
            }

            function animate() {
                ctx.clearRect(0, 0, w, h);
                particles.forEach(p => { p.update(); p.draw(); });
                requestAnimationFrame(animate);
            }

            function createShootingStar() {
                const container = document.getElementById('shooting-stars');
                if(!container) return;
                const star = document.createElement('div');
                star.style.position = 'absolute'; star.style.width = '2px'; star.style.height = '2px';
                star.style.background = '#fff'; star.style.boxShadow = '0 0 10px #fff'; star.style.borderRadius = '50%';
                const startX = Math.random() * window.innerWidth;
                const startY = Math.random() * window.innerHeight * 0.5;
                const duration = Math.random() * 1000 + 700;
                star.style.left = startX + 'px'; star.style.top = startY + 'px'; star.style.opacity = '1';
                star.style.transition = `all ${duration}ms cubic-bezier(0.1, 0.1, 0.1, 1)`;
                container.appendChild(star);
                setTimeout(() => { star.style.left = (startX + 600) + 'px'; star.style.top = (startY + 600) + 'px'; star.style.opacity = '0'; star.style.width = '100px'; star.style.transform = 'rotate(-45deg)'; }, 20);
                setTimeout(() => { if(container.contains(star)) container.removeChild(star); }, duration + 100);
            }
            setInterval(() => { if(Math.random() > 0.5) createShootingStar(); }, 3000);
            window.addEventListener('resize', init);
            init(); animate();
        })();

        // --- QUILL INITIALIZATION ---
        const quill = new Quill('#quill-editor', {
            theme: 'snow',
            placeholder: '硫붿씪蹂몃Ц?쓣 ?옉?꽦?븯?꽭?슂. {?긽?샇}??? {????몴?옄} ?깭洹몃뒗 諛쒖넚 ?떆 ?떎?젣 ?뜲?씠?꽣濡? ?옄?룞 移섑솚?맗?땲?떎.',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, false] }],
                    ['bold', 'italic', 'underline'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'color': [] }, { 'background': [] }],
                    ['link', 'image'],
                    ['clean']
                ]
            }
        });

        function insertMacro(tag) {
            const range = quill.getSelection();
            if (range) {
                quill.insertText(range.index, tag);
            } else {
                quill.insertText(quill.getLength() - 1, tag);
            }
        }

        function clearEmailBody() {
            if(confirm('?옉?꽦 以묒씤 蹂몃Ц ?궡?슜?씠 紐⑤몢 ?궘?젣?맗?땲?떎. 珥덇린?솕?븯?떆寃좎뒿?땲源??')) {
                quill.root.innerHTML = '';
            }
        }

        async function loadPreviousEmailBody() {
            if(confirm('?씠?쟾?뿉 諛쒖넚?뻽?뜕 媛??옣 理쒓렐?쓽 硫붿씪 蹂몃Ц?쓣 遺덈윭?삤?떆寃좎뒿?땲源??\\n?쁽?옱 ?옉?꽦 以묒씤 ?궡?슜??? 紐⑤몢 ?뜮?뼱?뵆?썙吏묐땲?떎.')) {
                const data = await fetchAPI('/api/email/latest-body');
                if (data && data.success && data.body) {
                    quill.root.innerHTML = data.body;
                } else {
                    alert(data?.message || '?씠?쟾 諛쒖넚 蹂몃Ц?쓣 李얠쓣 ?닔 ?뾾?뒿?땲?떎.');
                }
            }
        }

        // --- STATE & API LOGIC (MAINTAINED) ---
        let selectedBizNos = new Set();
        let expandedGroups = new Set();
        let currentCategory = 'GENERAL';
        let targetCategory = 'GENERAL';
        let uploadedAttachments = []; // Consolidated declaration
        let cachedCompanies = [];
        
        let globalTargetGroups = [];
        let currentRegionFilter = 'ALL';
        let activeGroupIds = new Set();

        function formatBizNo(bizNo) {
            if(!bizNo) return '-';
            const clean = bizNo.toString().replace(/[^\d]/g, '');
            if(clean.length === 10) return `${clean.substring(0,3)}-${clean.substring(3,5)}-${clean.substring(5,10)}`;
            return clean;
        }

        // ?엯?젰 ?븘?뱶 ?떎?떆媛? ?룷留룻똿 留덉뒪?겕
        function applyBizNoMask(input) {
            let val = input.value.replace(/[^0-9]/g, "");
            if (val.length > 10) val = val.substring(0, 10);
            
            if (val.length > 5) {
                input.value = `${val.substring(0, 3)}-${val.substring(3, 5)}-${val.substring(5)}`;
            } else if (val.length > 3) {
                input.value = `${val.substring(0, 3)}-${val.substring(3)}`;
            } else {
                input.value = val;
            }
        }

        // 珥덇린?솕 諛? ?씠踰ㅽ듃 諛붿씤?뵫
        document.addEventListener('DOMContentLoaded', () => {
            const bizInputs = ['add-biz-no', 'edit-biz-no'];
            bizInputs.forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.addEventListener('input', (e) => applyBizNoMask(e.target));
                }
            });
        });

        function showTab(tabId) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            const btn = document.querySelector(`.tab-btn[onclick="showTab('${tabId}')"]`);
            if (btn) btn.classList.add('active');
            document.getElementById(`tab-${tabId}`).classList.add('active');
            if (tabId === 'company') loadCompanies();
            if (tabId === 'smtp' || tabId === 'send') loadSmtpConfigs();
            if (tabId === 'target') loadTargetGroups();
            if (tabId === 'history') loadBatches();
            if (tabId === 'result') loadDispatchStats();
        }

        async function fetchAPI(url, options = {}) {
            try { 
                const res = await fetch(url, options);
                const text = await res.text();
                try {
                    return JSON.parse(text);
                } catch(parseErr) {
                    // HTML Response (likely 500 or 404)
                    console.error("Non-JSON Server Response:", text);
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(text, 'text/html');
                    // Extract title or first paragraph/body for debugging
                    const errorDetails = doc.body ? doc.body.innerText.trim().substring(0, 300) : text.substring(0, 300);
                    return { success: false, message: `Server Error (${res.status}): ${errorDetails}` };
                }
            } catch(e) { 
                console.error("Network Fetch Error:", e); 
                return { success: false, message: "?넻?떊 ?삤瑜?: " + e.toString() }; 
            }
        }

        async function loadCompanies(keyword = '') {
            const list = document.getElementById('company-list');
            const emailStatus = document.getElementById('filter-email-status').value;
            const searchKw = keyword || document.getElementById('company-keyword').value;
            list.innerHTML = '<tr><td colspan="7" style="text-align:center;">SCANNING INFRA...</td></tr>';
            
            const url = `/api/email/companies?category=${currentCategory}&email_status=${emailStatus}&keyword=${encodeURIComponent(searchKw)}`;
            const data = await fetchAPI(url);
            
            if (data.success) {
                cachedCompanies = data.companies;
                list.innerHTML = data.companies.map(c => {
                    const isAbnormal = !c.email || c.email_usable === 0;
                    return `
                        <tr style="border-bottom: 1px solid #F3EFE0; transition: background 0.2s;" onmouseover="this.style.background='#FDFCF5'" onmouseout="this.style.background='white'">
                            <td style="padding: 14px; font-weight: 600;">${c.company_name}</td>
                            <td style="padding: 14px; font-family:Orbitron; font-size:0.75rem; letter-spacing:1px; color: #4A5568;">${formatBizNo(c.biz_no)}</td>
                            <td style="padding: 14px;">${c.representative_name}</td>
                            <td style="padding: 14px; color:${isAbnormal ? '#ff4d4d' : '#000'}; font-weight: 500;">${c.email || '<span style="color:#ff4d4d; font-weight:800;">N/A</span>'}</td>
                            <td style="padding: 14px; font-size:0.85rem; color: #4A5568;">${c.region || '-'}</td>
                            <td style="padding: 14px; text-align:center;">
                                <span class="badge ${isAbnormal ? 'badge-danger' : 'badge-success'}" style="box-shadow: 2px 2px 6px rgba(0,0,0,0.1); border-radius: 6px;">${isAbnormal ? '鍮꾩젙?긽' : '?젙?긽'}</span>
                            </td>
                            <td style="padding: 14px; text-align:center;">
                                <button class="btn btn-outline" style="padding:6px 14px; font-size:0.75rem; background: #fff; border: 1px solid #D1CBB5; color: #4A4A4A; box-shadow: 1px 1px 4px rgba(0,0,0,0.08); font-weight: 700; border-radius: 8px;" onclick="editCompany('${c.biz_no}')">?닔?젙</button>
                            </td>
                        </tr>
                    `;
                }).join('');
            }
        }

        function filterCategory(cat) {
            currentCategory = cat;
            document.querySelectorAll('[id^="btn-corp-"]').forEach(b => b.className = 'btn btn-outline');
            document.getElementById(`btn-corp-${cat.toLowerCase()}`).className = 'btn btn-primary';
            loadCompanies();
        }

        async function loadSmtpConfigs() {
            const data = await fetchAPI('/api/v3/email-setup');
            if (data.success) {
                const list = document.getElementById('smtp-list');
                const select = document.getElementById('send-smtp-id');
                list.innerHTML = data.configs.map(cfg => {
                    const cfgJson = JSON.stringify(cfg).replace(/"/g, '&quot;');
                    return `
                    <tr>
                        <td>${cfg.config_name}</td>
                        <td>${cfg.smtp_server}</td>
                        <td>${cfg.smtp_port}</td>
                        <td style="color:var(--neon-cyan);">${cfg.sender_email}</td>
                        <td><span class="badge badge-success">?솢?꽦</span></td>
                        <td>
                            <div style="display:flex; gap:5px; align-items:center;">
                                <button class="btn btn-outline" style="padding:4px 10px; font-size:0.75rem;" onclick="editSmtp(${cfgJson})">?닔?젙</button>
                                <button class="btn btn-outline" style="padding:4px 10px; font-size:0.75rem; border-color:#ff6b6b; color:#ff6b6b;" onclick="deleteSmtp(${cfg.config_id})">?궘?젣</button>
                            </div>
                        </td>
                    </tr>`;
                }).join('');
                select.innerHTML = '<option value="">-- 寃뚯씠?듃?썾?씠 ?꽑?깮 --</option>' + data.configs.map(cfg => `<option value="${cfg.config_id}">${cfg.config_name} (${cfg.sender_email})</option>`).join('');
            }
        }

        function updateTargetCategory(cat) {
            targetCategory = cat;
            const isRisk = document.getElementById('risk-mode-check').checked;
            const banner = document.getElementById('filter-info-text');
            
            let text = "";
            if (isRisk) {
                text = "?솕?옱/?븞?쟾 ?궗怨? ?쐞?뿕?룄媛? ?넂??? ?젣議? 諛? 臾쇰쪟 ?뾽醫낆쓣 ?슦?꽑 遺꾨쪟?빀?땲?떎.";
            } else {
                if (cat === 'GENERAL') text = "?씪諛? 以묒냼湲곗뾽(???湲곗뾽/?궗?떒踰뺤씤 ?젣?쇅)?쓣 吏??뿭蹂꾨줈 遺꾨쪟?빀?땲?떎.";
                else if (cat === 'MANAGED') text = "愿?由щ???긽?쓽 紐⑤뱺 ?쑀?슚 ?씠硫붿씪 湲곗뾽?쓣 吏??뿭蹂꾨줈 遺꾨쪟?빀?땲?떎.";
                else text = "?깒?뱶諛뺤뒪 ?뀒?뒪?듃?슜 ?뜲?씠?꽣瑜? 吏??뿭蹂꾨줈 援ъ꽦?빀?땲?떎.";
            }
            
            banner.innerHTML = `<i class="fas fa-info-circle" style="color:var(--neon-blue); margin-right:8px;"></i> <strong>?쁽?옱 ?븘?꽣留? 洹쒖튃:</strong> ${text}`;
            loadTargetGroups();
        }

        async function generateSmartGroups() {
            const isRiskMode = document.getElementById('risk-mode-check').checked;
            const riskMsg = isRiskMode ? "\n(怨좎쐞?뿕 ?젣議?/臾쇰쪟 ?뾽醫? ?슦?꽑 紐⑤뱶媛? ?솢?꽦 ?긽?깭?엯?땲?떎.)" : "";
            
            if(!confirm(`${targetCategory} 移댄뀒怨좊━?쓽 湲곗뾽?쓣 100嫄댁뵫 洹몃９?븨?븯?떆寃좎뒿?땲源??${riskMsg}`)) return;
            
            const btn = event.target.closest('button');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ?봽濡쒖꽭?떛...';
            
            try {
                const data = await fetchAPI('/api/email/generate-groups', {
                    method: 'POST', headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ category: targetCategory, limit: 100, is_risk_mode: isRiskMode })
                });
                
                if (data.success) {
                    alert(`珥? ${data.total_companies}媛? 湲곗뾽?쓣 ${data.num_groups}媛? 洹몃９?쑝濡? 遺꾪븷 ?셿猷뚰븯????뒿?땲?떎.`);
                    loadTargetGroups();
                } else {
                    alert("洹몃９?븨 ?떎?뙣: " + data.message);
                }
            } catch (err) {
                alert("?꽕?듃?썙?겕 ?삤瑜섍?? 諛쒖깮?뻽?뒿?땲?떎.");
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        async function cleanupGroups() {
            if(!confirm("?깮?꽦?맂 紐⑤뱺 洹몃９ ?젙蹂대?? 珥덇린?솕?븯?떆寃좎뒿?땲源??\n諛쒖넚 ???湲곗뿴 ?젙蹂대룄 ?궘?젣?맗?땲?떎.")) return;
            const data = await fetchAPI('/api/email/cleanup-groups', { method: 'POST' });
            if(data.success) {
                alert("洹몃９ ?젙蹂닿?? 珥덇린?솕?릺?뿀?뒿?땲?떎.");
                selectedBizNos.clear();
                loadTargetGroups();
            } else {
                alert("珥덇린?솕 ?떎?뙣: " + data.message);
            }
        }

        function updateRegionFilter(region) {
            currentRegionFilter = region;
            renderTargetGroups();
        }

        const regionColors = {
            '?꽌?슱': '#00d2d3', '寃쎄린': '#4ecdc4', '?씤泥?': '#45b7d1', '媛뺤썝': '#96ceb4', 
            '異⑹껌': '#ffeead', '????쟾': '#feca57', '遺??궛': '#00b894', '?슱?궛': '#0984e3', 
            '???援?': '#6c5ce7', '愿묒＜': '#fdcb6e', '?쟾?궓': '#5f27cd', '?쟾遺?': '#10ac84', 
            '寃쎈궓': '#54a0ff', '寃쎈턿': '#a29bfe', '?젣二?': '#ffeaa7', '?꽭醫?': '#81ecec',
            'DEFAULT': 'var(--neon-blue)'
        };

        async function loadTargetGroups() {
            const container = document.getElementById('target-groups');
            container.innerHTML = '<div style="color:var(--text-secondary); padding: 50px; text-align:center;">MAPPING QUANTUM CLUSTERS...</div>';
            const data = await fetchAPI(`/api/email/target-groups?category=${targetCategory}`);
            if (data.success) {
                globalTargetGroups = data.groups;
                
                // Extract unique regions for the buttons
                let regions = new Set();
                globalTargetGroups.forEach(g => {
                    const parts = g.range.split('_');
                    if(parts.length > 0) regions.add(parts[0]);
                });
                
                const rCont = document.getElementById('region-filter-container');
                const rBtns = document.getElementById('region-buttons-container');
                if (regions.size > 0) {
                    rCont.style.display = 'block';
                    let btnsHtml = `<button class="btn ${currentRegionFilter === 'ALL' ? 'btn-primary' : 'btn-outline'}" onclick="updateRegionFilter('ALL')" style="padding: 6px 12px; font-size: 0.8rem; border-radius: 20px;">?쟾泥?</button>`;
                    Array.from(regions).sort().forEach(r => {
                        const isSel = (currentRegionFilter === r);
                        const c = regionColors[r] || regionColors['DEFAULT'];
                        if (isSel) {
                            btnsHtml += `<button class="btn" onclick="updateRegionFilter('${r}')" style="padding: 6px 12px; font-size: 0.8rem; border-radius: 20px; background: ${c}33; border: 1px solid ${c}; color: ${c}; box-shadow: 0 0 10px ${c}66;">${r}</button>`;
                        } else {
                            btnsHtml += `<button class="btn" onclick="updateRegionFilter('${r}')" style="padding: 6px 12px; font-size: 0.8rem; border-radius: 20px; background: rgba(255,255,255,0.02); border: 1px solid ${c}55; color: ${c}cc; transition: 0.3s;" onmouseover="this.style.background='${c}22'; this.style.borderColor='${c}'" onmouseout="this.style.background='rgba(255,255,255,0.02)'; this.style.borderColor='${c}55'">${r}</button>`;
                        }
                    });
                    rBtns.innerHTML = btnsHtml;
                } else {
                    rCont.style.display = 'none';
                }
                
                renderTargetGroups();
                updateSelectedSummary();
            }
        }
        
        function renderTargetGroups() {
            const container = document.getElementById('target-groups');
            if (globalTargetGroups.length === 0) {
                container.innerHTML = '<div style="color:var(--text-secondary); padding:50px; text-align:center;">?깮?꽦?맂 洹몃９?씠 ?뾾?뒿?땲?떎. ?긽?떒?쓽 ?옄?룞 洹몃９?븨?쓣 ?떎?뻾?븯?꽭?슂.</div>';
                return;
            }
            
            // Filter by Region
            let filtered = globalTargetGroups;
            if (currentRegionFilter !== 'ALL') {
                filtered = filtered.filter(g => g.range.startsWith(currentRegionFilter));
            }
            
            container.innerHTML = filtered.map(g => {
                const isExpanded = expandedGroups.has(g.id);
                const isSelected = activeGroupIds.has(g.id);
                const sentTimes = g.sent_times || 0;
                
                const regionMatches = g.range.split('_');
                const regionCode = regionMatches.length > 0 ? regionMatches[0] : '';
                
                // --- 援щ텇 濡쒖쭅 (?젣議?/?쐞?뿕 vs ?씪諛?) ---
                const isRisk = g.range.includes('_?젣議?_');
                const riskColor = '#f97316'; // Amber/Orange for Risk
                const generalColor = regionColors[regionCode] || regionColors['DEFAULT'];
                const accentColor = isRisk ? riskColor : generalColor;
                const riskBadge = isRisk 
                    ? `<span style="background:${riskColor}22; color:${riskColor}; border:1px solid ${riskColor}55; padding:2px 8px; border-radius:5px; font-size:0.6rem; vertical-align:middle; margin-left:8px; font-weight:800;">?쐞?뿕 ?뾽醫?(?젣議?/臾쇰쪟)</span>`
                    : `<span style="background:rgba(255,255,255,0.05); color:var(--text-secondary); border:1px solid rgba(255,255,255,0.1); padding:2px 8px; border-radius:5px; font-size:0.6rem; vertical-align:middle; margin-left:8px;">?씪諛? 湲곗뾽</span>`;

                let colorCode = 'var(--neon-blue)';
                if (sentTimes === 1) colorCode = '#facc15';
                else if (sentTimes === 2) colorCode = '#f97316';
                else if (sentTimes >= 3) colorCode = '#ef4444';
                
                const nodeText = `<span style="color:${colorCode};">${g.count} NODES` + (sentTimes > 0 ? ` : ${sentTimes} 踰덈컻?넚` : '') + (g.success_count || g.fail_count ? ` (?젙?긽: ${g.success_count || 0}, ?떎?뙣: ${g.fail_count || 0})` : '') + `</span>`;
                
                let borderStyle = isSelected 
                    ? `border: 2px solid ${accentColor}; background: ${accentColor}15; box-shadow: 0 0 20px ${accentColor}55;` 
                    : `border-top: 4px solid ${accentColor}; border-left: 1px solid rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05);`;

                return `
                    <div id="group-card-${g.id}" class="group-box" style="${borderStyle}" onclick="handleGroupClick(event, ${g.id}, '${g.range}')">
                        <button class="group-expand-btn" onclick="toggleExpand(event, ${g.id})">
                            <i class="fas ${isExpanded ? 'fa-chevron-up' : 'fa-chevron-down'}"></i>
                        </button>
                        <div style="display:flex; align-items:center; margin-bottom:10px;">
                            <div class="title" style="color: ${accentColor}; text-shadow: 0 0 5px ${accentColor}88; margin-bottom:0;">BATCH CLUSTER</div>
                            ${riskBadge}
                        </div>
                        <div class="range" style="color:#fff; font-weight:700;">${g.range}</div>
                        <div style="font-size: 0.7rem;">${nodeText}</div>
                        
                        <div id="members-${g.id}" class="members-list ${isExpanded ? 'active' : ''}">
                            ${isExpanded ? 'SCANNING NODES...' : ''}
                        </div>
                    </div>
                `;
            }).join('');
            
            if (expandedGroups.size > 0) {
                expandedGroups.forEach(id => refreshGroupMembers(id));
            }
        }

        async function toggleExpand(event, groupId) {
            event.stopPropagation();
            if (expandedGroups.has(groupId)) {
                expandedGroups.delete(groupId);
            } else {
                expandedGroups.add(groupId);
            }
            loadTargetGroups();
        }

        async function refreshGroupMembers(groupId) {
            const listEl = document.getElementById(`members-${groupId}`);
            if (!listEl) return;
            
            const data = await fetchAPI(`/api/email/group-members/${groupId}`);
            if (data.success) {
                listEl.innerHTML = `
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; padding:0 10px;">
                        <span style="font-size:0.75rem; color:var(--neon-cyan);">INNER NODES</span>
                        <div style="display:flex; gap:5px;">
                            <button class="btn btn-outline" style="padding:4px 8px; font-size:0.6rem;" onclick="selectAllInGroup(event, ${groupId})">?쟾泥? ?꽑?깮</button>
                            <button class="btn btn-outline" style="padding:4px 8px; font-size:0.6rem; background: rgba(255, 100, 100, 0.1); border-color: rgba(255, 100, 100, 0.3); color: #ff6b6b;" onclick="excludeFailedEmails(event, ${groupId})">?떎?뙣嫄? ?젣?쇅</button>
                        </div>
                    </div>
                    ${data.members.map(m => `
                        <div class="member-item">
                            <input type="checkbox" class="member-checkbox" ${selectedBizNos.has(m.biz_no) ? 'checked' : ''} 
                                   onchange="toggleMemberSelection('${m.biz_no}')">
                            <div style="flex:1;">
                                <div style="font-weight:700;">${m.company_name}</div>
                                <div style="font-size:0.7rem; color:var(--text-secondary);">${formatBizNo(m.biz_no)} | ${m.email || '<span style="color:#ff4d4d;">N/A</span>'}</div>
                            </div>
                        </div>
                    `).join('')}
                `;
            }
        }

        function handleGroupClick(event, groupId, groupName) {
            if (event.target.closest('.group-expand-btn') || event.target.closest('.members-list')) return;
            selectAllInGroup(event, groupId);
        }

        function formatStatusBadge(status) {
            const s = (status || '').toUpperCase();
            let color = 'var(--text-secondary)';
            let label = s;
            
            if (s === 'COMPLETED' || s === 'SUCCESS') { color = 'var(--neon-green)'; label = '?셿猷?'; }
            else if (s === 'SENDING' || s === 'SEND' || s === 'PROCESSING') { color = 'var(--neon-cyan)'; label = '諛쒖넚以?'; }
            else if (s === 'ERROR' || s === 'FAIL' || s === 'FAILED' || s === 'BOUNCE') { color = '#f87171'; label = '?삤瑜?'; }
            
            return `<span class="badge" style="
                border-color: ${color}44; 
                color: ${color}; 
                background: ${color}11; 
                white-space: nowrap; 
                display: inline-block;
                min-width: 65px;
                text-align: center;
                padding: 4px 12px;
                font-weight: 700;
                font-size: 0.75rem;
                letter-spacing: 0px;
                border-radius: 20px;
            ">${label}</span>`;
        }

        function deselectAllGroups() {
            if (selectedBizNos.size === 0) return;
            
            selectedBizNos.clear();
            activeGroupIds.clear();
            
            globalTargetGroups.sort((a, b) => a.id - b.id);
            
            renderTargetGroups();
            updateSelectedSummary();
        }

        async function selectAllInGroup(event, groupId) {
            if (event) event.stopPropagation();
            const data = await fetchAPI(`/api/email/group-members/${groupId}`);
            if (data.success) {
                const someMissing = data.members.some(m => !selectedBizNos.has(m.biz_no));
                if (someMissing) {
                    data.members.forEach(m => selectedBizNos.add(m.biz_no));
                    activeGroupIds.add(groupId);
                } else {
                    data.members.forEach(m => selectedBizNos.delete(m.biz_no));
                    activeGroupIds.delete(groupId);
                }
                
                globalTargetGroups.sort((a, b) => {
                    const aSel = activeGroupIds.has(a.id);
                    const bSel = activeGroupIds.has(b.id);
                    if (aSel === bSel) return a.id - b.id;
                    return aSel ? -1 : 1;
                });
                
                renderTargetGroups();
                updateSelectedSummary();
            }
        }

        function toggleMemberSelection(bizNo) {
            if (selectedBizNos.has(bizNo)) {
                selectedBizNos.delete(bizNo);
            } else {
                selectedBizNos.add(bizNo);
            }
            updateSelectedSummary();
        }

        function updateSelectedSummary() {
            const summaryEl = document.getElementById('selected-groups-summary');
            if (selectedBizNos.size > 0) {
                summaryEl.innerHTML = `
                    <div style="display: flex; align-items: center; gap: 15px; background: rgba(0, 212, 255, 0.1); padding: 25px; border-radius: 20px; border: 1px solid var(--neon-blue); box-shadow: 0 0 20px rgba(0, 212, 255, 0.2);">
                        <i class="fas fa-satellite-dish" style="font-size: 2rem; color: var(--neon-blue); animation: pulse 2s infinite;"></i>
                        <div>
                            <div style="font-family: 'Orbitron', 'Noto Sans KR', sans-serif; font-size: 0.75rem; color: var(--neon-cyan); letter-spacing: 2px; margin-bottom: 5px;">?솢?꽦 ???寃? (ACTIVE)</div>
                            <div style="font-size: 1.8rem; font-weight: 900; color: #fff; text-shadow: 0 0 10px var(--neon-blue);">
                                ${selectedBizNos.size.toLocaleString()} <span style="font-size: 0.9rem; font-weight: 500; color: var(--text-secondary);">媛? ?끂?뱶 以?鍮꾨맖</span>
                            </div>
                        </div>
                    </div>
                `;
            } else {
                summaryEl.innerHTML = `
                    <div style="color: var(--text-secondary); padding: 20px; text-align: center; border: 1px dashed rgba(255,255,255,0.1); border-radius: 20px;">
                        <i class="fas fa-crosshairs" style="font-size: 1.5rem; margin-bottom:10px; display:block;"></i>
                        以?鍮꾨맂 ???寃잛씠 ?뾾?뒿?땲?떎.
                    </div>
                `;
            }
        }

        async function startDispatch() {
            const smtpId = document.getElementById('send-smtp-id').value;
            const subject = document.getElementById('email-subject').value;
            const content = quill.root.innerHTML;
            
            if(!smtpId) return alert("SMTP 寃뚯씠?듃?썾?씠瑜? ?꽑?깮?빐二쇱꽭?슂.");
            if(!subject) return alert("硫붿씪 ?젣紐⑹쓣 ?엯?젰?빐二쇱꽭?슂.");
            if(selectedBizNos.size === 0) return alert("諛쒖넚 ????긽 湲곗뾽?씠 ?꽑?깮?릺吏? ?븡?븯?뒿?땲?떎.");
            
            if(!confirm(`珥? ${selectedBizNos.size}嫄댁쓽 ?????? 諛곗튂瑜? ?떆?옉?븯?떆寃좎뒿?땲源??`)) return;

            document.getElementById('progress-overlay').style.display = 'flex';
            document.getElementById('gauge-percent').innerText = '0%';
            document.getElementById('gauge-progress').style.strokeDashoffset = 628;
            document.getElementById('progress-summary').innerText = '?쟾?넚 ?뿏吏? 珥덇린?솕 以?...';
            document.getElementById('btn-progress-close').style.display = 'none';

            const res = await fetchAPI('/api/email/batch-send', {
                method: 'POST', 
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ 
                    smtp_config_id: smtpId, 
                    subject, 
                    body: content, 
                    biz_nos: Array.from(selectedBizNos),
                    attachments: uploadedAttachments
                })
            });

            if (res.success) trackProgress(res.batch_id);
            else {
                alert("諛쒖넚 ?떎?뙣: " + res.message);
                document.getElementById('progress-overlay').style.display = 'none';
            }
        }

        function trackProgress(batchId) {
            let pollErrorCount = 0;
            const interval = setInterval(async () => {
                const data = await fetchAPI(`/api/email/batch-status/${batchId}`);
                if (data.success) {
                    pollErrorCount = 0;
                    const status = data.status;
                    const processed = status.processed_count !== undefined ? status.processed_count : (status.sent || 0);
                    const successCnt = status.success_count !== undefined ? status.success_count : (status.success || 0);
                    const failCnt   = status.fail_count    !== undefined ? status.fail_count    : (status.fail    || 0);
                    const total     = status.total_count   !== undefined ? status.total_count   : (status.total   || 1);
                    const percent   = total > 0 ? Math.round((processed / total) * 100) : 0;
                    
                    const gaugeCircle = document.getElementById('gauge-progress');
                    if (gaugeCircle) {
                        gaugeCircle.style.setProperty('--gauge-percent', percent);
                    }
                    document.getElementById('gauge-percent').textContent = percent + '%';
                    document.getElementById('progress-success').textContent = successCnt;
                    document.getElementById('progress-fail').textContent = failCnt;
                    document.getElementById('progress-summary').textContent = `${processed.toLocaleString()} / ${total.toLocaleString()} ?쑀?떅 泥섎━ 以?...`;
                    
                    const st = (status.status || '').toLowerCase();
                    if (st === 'completed' || st === 'send' || st === 'error' || st === 'failed') {
                        clearInterval(interval);
                        document.getElementById('btn-progress-close').style.display = 'block';
                        if (st === 'error' || st === 'failed') {
                            document.getElementById('progress-summary').innerHTML = `<i class="fas fa-exclamation-triangle" style="color:#f87171;"></i> ?뿏吏? ?씪?떆 以묐떒: ${status.last_error || '?꽕?듃?썙?겕 ?삤瑜?'}`;
                        } else {
                            document.getElementById('progress-summary').innerHTML = `
                                <div style="color:var(--neon-cyan); font-weight:700; margin-bottom:10px;">?윓? ?????? 諛곗튂 諛쒖넚 ?셿猷?!</div>
                                <div style="font-size:0.8rem; color:var(--text-secondary); line-height:1.5;">
                                    議댁옱?븯吏? ?븡?뒗 二쇱냼(?돩利? ?솃留덉폆 ?벑)?쓽 諛섏넚 硫붿씪???<br>
                                    ?꽌踰? ?궗?젙?뿉 ?뵲?씪 <strong>?닔 遺? ?뮘</strong>?뿉 ?룄李⑺빀?땲?떎.<br>
                                    ?옞?떆 ?썑 [諛쒖넚 ?쁽?솴] ?꺆?뿉?꽌 <strong>諛섏넚 ?뒪罹?</strong>?쓣 ?떎?뻾?빐二쇱꽭?슂.
                                </div>`;
                        }
                        loadBatches();
                    }
                } else {
                    pollErrorCount++;
                    if (pollErrorCount >= 5) {
                        clearInterval(interval);
                        document.getElementById('btn-progress-close').style.display = 'block';
                        document.getElementById('progress-summary').textContent = '?긽?깭 議고쉶 ?삤瑜? - 諛쒖넚 ?씠?젰 ?꺆?뿉?꽌 寃곌낵瑜? ?솗?씤?븯?꽭?슂.';
                    }
                }
            }, 1500);
        }

        async function handleFileSelect(event) { await uploadFiles(event.target.files); }
        async function handleDrop(event) {
            event.preventDefault();
            const dropZone = document.getElementById('drop-zone');
            if(dropZone) dropZone.style.borderColor = 'rgba(0, 212, 255, 0.2)';
            await uploadFiles(event.dataTransfer.files);
        }

        async function uploadFiles(files) {
            if (files.length === 0) return;
            const formData = new FormData();
            for (let f of files) formData.append('files', f);
            
            try {
                const res = await fetch('/api/email/upload-attachments', { method: 'POST', body: formData });
                const result = await res.json();
                if (result.success) {
                    uploadedAttachments = [...uploadedAttachments, ...result.files];
                    renderFileList();
                } else alert('?뾽濡쒕뱶 ?떎?뙣: ' + result.message);
            } catch(e) { alert('?뙆?씪 ?쟾?넚 以? ?삤瑜섍?? 諛쒖깮?뻽?뒿?땲?떎.'); }
        }

        function renderFileList() {
            const list = document.getElementById('file-list');
            list.innerHTML = uploadedAttachments.map((f, i) => `
                <div style="background: rgba(255,255,255,0.05); padding: 10px 15px; border-radius: 12px; display: flex; align-items: center; justify-content: space-between; font-size: 0.8rem; border: 1px solid rgba(0, 212, 255, 0.1);">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <i class="fas fa-file-alt" style="color: var(--neon-cyan);"></i>
                        <span style="max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${f.name}</span>
                    </div>
                    <i class="fas fa-times" style="cursor: pointer; color: #ff6b6b;" onclick="removeAttachment(${i})"></i>
                </div>
            `).join('');
        }
        function removeAttachment(index) { uploadedAttachments.splice(index, 1); renderFileList(); }

        function formatDateTime(dt) {
            if (!dt) return '-';
            try { return new Date(dt).toLocaleString('ko-KR', {year:'2-digit',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'}); }
            catch(e) { return String(dt).substring(0, 16); }
        }

        async function loadBatches() {
            const data = await fetchAPI('/api/email/batches');
            if (data.success) {
                if (data.batches.length === 0) {
                    document.getElementById('batch-list').innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--text-secondary);padding:40px;">諛쒖넚 ?씠?젰?씠 ?뾾?뒿?땲?떎.</td></tr>';
                    return;
                }
                document.getElementById('batch-list').innerHTML = data.batches.map(b => {
                    const total = b.total_count || 0;
                    const sent  = b.sent_count  || 0;
                    const succ  = b.success_count || 0;
                    const fail  = b.fail_count   || 0;
                    // ?궇吏? ?븘?뱶: sent_at ?삉?뒗 created_at ?몮 ?떎 吏??썝
                    const rawDt = b.sent_at || b.created_at || '';
                    const rate  = total > 0 ? Math.round((succ / total) * 100) : 0;
                    const rateColor = rate >= 80 ? '#4ade80' : rate >= 50 ? '#fbbf24' : '#f87171';
                    
                    const batchIdStr = (b.batch_id || b.id || '').toString();
                    const sendDate = rawDt.split(' ')[0];
                    const displayTime = rawDt.includes(' ') ? rawDt.split(' ')[1].substring(0, 5) : '';
                    const cleanTitle = (b.subject || b.group_name || '').toLowerCase();

                    return `
                    <tr class="batch-data-row" data-id="${batchIdStr}" data-title="${cleanTitle}" data-date="${sendDate}" style="height: 60px;">
                        <td style="width:40px; text-align:center; vertical-align:middle;">
                            <input type="checkbox" class="batch-check-item member-checkbox" value="${batchIdStr}">
                        </td>
                        <td style="width:90px; vertical-align:middle; font-family:Orbitron; font-size:0.65rem; color:var(--neon-cyan); white-space:nowrap; overflow:hidden;">#${batchIdStr.substring(0,8)}</td>
                        <td style="vertical-align:middle; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="${b.subject || b.group_name}">${b.subject || b.group_name || '-'}</td>
                        <td style="width:55px; text-align:center; vertical-align:middle;">${total.toLocaleString()}</td>
                        <td style="width:55px; text-align:center; vertical-align:middle; color:var(--neon-blue);">${sent.toLocaleString()}</td>
                        <td style="width:55px; text-align:center; vertical-align:middle; color:#4ade80;">${succ.toLocaleString()}</td>
                        <td style="width:55px; text-align:center; vertical-align:middle; color:#f87171;">${fail.toLocaleString()}</td>
                        <td style="width:65px; text-align:center; vertical-align:middle;">
                            <span style="color:${rateColor}; font-weight:800; font-size:0.8rem;">${rate}%</span>
                        </td>
                        <td style="width:140px; vertical-align:middle; font-size:0.75rem; color:var(--text-secondary); white-space:nowrap; overflow:hidden;">
                            ${sendDate} <span style="opacity:0.6; font-size:0.65rem; margin-left:2px;">${displayTime}</span>
                        </td>
                        <td style="width:95px; text-align:center; vertical-align:middle; white-space:nowrap;">${formatStatusBadge(b.status)}</td>
                        <td style="width:85px; text-align:center; vertical-align:middle;">
                            <button class="btn btn-outline" style="padding:4px 8px; font-size:0.65rem; font-family:Orbitron;" onclick="viewBatchDetails('${batchIdStr}')">
                                <i class="fas fa-list-ul"></i> LOG
                            </button>
                        </td>
                    </tr>`;
                }).join('');
            }
        }

        async function viewBatchDetails(batchId) {
            const data = await fetchAPI(`/api/email/batch-details/${batchId}`);
            if (data.success) {
                const area = document.getElementById('batch-details-area');
                area.style.display = 'block';
                if (data.details.length === 0) {
                    document.getElementById('batch-details-list').innerHTML = '<tr><td colspan="4" style="text-align:center; color:var(--text-secondary); padding:30px;">?긽?꽭 濡쒓렇媛? ?뾾?뒿?땲?떎.</td></tr>';
                } else {
                    document.getElementById('batch-details-list').innerHTML = data.details.map(d => {
                        const st = (d.status || '').toUpperCase();
                        const isSuccess = st === 'SUCCESS' || st === 'DELIVERED';
                        const isFail = st === 'FAIL' || st === 'ERROR' || st === 'FAILED';
                        return `
                        <tr>
                            <td>${d.company_name || '-'}</td>
                            <td style="color:var(--neon-blue); font-size:0.85rem;">${d.email || '-'}</td>
                            <td>${formatStatusBadge(d.status)}</td>
                            <td style="font-size:0.7rem; color:${isFail ? '#f87171' : 'var(--text-secondary)'}; max-width:300px;">${d.error_msg || d.error_message || (isSuccess ? '?젙?긽 諛쒖넚' : '-')}</td>
                        </tr>`;
                    }).join('');
                }
                area.scrollIntoView({ behavior: 'smooth' });
            }
        }

        // --- 湲곗뾽 ?젙蹂? 怨좊룄?솕 諛? 移댄뀒怨좊━ 愿?由? ---
        function editCompany(bizNo) {
            const company = cachedCompanies.find(c => c.biz_no === bizNo);
            if (!company) return alert("濡쒖뺄 罹먯떆?뿉?꽌 ?뜲?씠?꽣瑜? 李얠쓣 ?닔 ?뾾?뒿?땲?떎. ?떎?떆 濡쒕뱶 以?...");
            
            document.getElementById('edit-biz-no').value = company.biz_no;
            document.getElementById('edit-company-name').value = company.company_name;
            document.getElementById('edit-email').value = company.email || '';
            
            const radios = document.getElementsByName('edit-category');
            radios.forEach(r => { if(r.value === company.category) r.checked = true; });
            
            document.getElementById('corp-edit-modal').style.display = 'flex';
        }

        async function saveEditCompany() {
            const bizNo = document.getElementById('edit-biz-no').value;
            const companyName = document.getElementById('edit-company-name').value;
            const email = document.getElementById('edit-email').value;
            const category = document.querySelector('input[name="edit-category"]:checked').value;
            
            const payload = { biz_no: bizNo, company_name: companyName, email: email, category: category };
            const data = await fetchAPI('/api/email/update-company', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            
            if (data.success) {
                alert("湲곗뾽 ?젙蹂댁?? 遺꾨쪟 泥닿퀎媛? ?꽦怨듭쟻?쑝濡? ?뾽?뜲?씠?듃?릺?뿀?뒿?땲?떎.");
                document.getElementById('corp-edit-modal').style.display = 'none';
                loadCompanies(document.getElementById('search-keyword').value);
            } else {
                alert("?뾽?뜲?씠?듃 ?떎?뙣: " + data.message);
            }
        }

        function filterCategory(cat) {
            currentCategory = cat;
            document.querySelectorAll('[id^="btn-corp-"]').forEach(b => b.className = 'btn btn-outline');
            const targetBtn = document.getElementById(`btn-corp-${cat.toLowerCase()}`);
            if(targetBtn) targetBtn.className = 'btn btn-primary';
            loadCompanies();
        }

        // --- Modals Logic (Maintained) ---
        function openCorpAddModal() { document.getElementById('corp-add-modal').style.display = 'flex'; }
        function closeCorpAddModal() { document.getElementById('corp-add-modal').style.display = 'none'; }
        
        function openSmtpModal() { 
            document.getElementById('smtp-id').value = '';
            document.getElementById('smtp-name').value = '';
            document.getElementById('smtp-server').value = '';
            document.getElementById('smtp-port').value = '465';
            document.getElementById('smtp-email').value = '';
            document.getElementById('smtp-password').value = '';
            document.getElementById('smtp-provider').value = '';
            document.getElementById('smtp-modal').style.display = 'flex'; 
        }
        function closeSmtpModal() { document.getElementById('smtp-modal').style.display = 'none'; }

        function handleSmtpProviderChange() {
            const provider = document.getElementById('smtp-provider').value;
            const sv = document.getElementById('smtp-server');
            const pt = document.getElementById('smtp-port');
            const nm = document.getElementById('smtp-name');
            
            if (provider === 'naver') { sv.value = 'smtp.naver.com'; pt.value = 465; if(!nm.value) nm.value = '?꽕?씠踰? 硫붿씪'; }
            else if (provider === 'gmail') { sv.value = 'smtp.gmail.com'; pt.value = 465; if(!nm.value) nm.value = '援ш?? 硫붿씪'; }
            else if (provider === 'kakao') { sv.value = 'smtp.kakao.com'; pt.value = 465; if(!nm.value) nm.value = '移댁뭅?삤 硫붿씪'; }
            else if (provider === 'hanmail') { sv.value = 'smtp.daum.net'; pt.value = 465; if(!nm.value) nm.value = '?떎?쓬 硫붿씪'; }
            else if (provider === 'nate') { sv.value = 'smtp.mail.nate.com'; pt.value = 465; if(!nm.value) nm.value = '?꽕?씠?듃 硫붿씪'; }
            else if (provider === 'custom') { sv.value = ''; pt.value = 465; }
        }

        function editSmtp(cfg) {
            document.getElementById('smtp-id').value = cfg.config_id || '';
            document.getElementById('smtp-name').value = cfg.config_name || '';
            document.getElementById('smtp-server').value = cfg.smtp_server || '';
            document.getElementById('smtp-port').value = cfg.smtp_port || 465;
            document.getElementById('smtp-email').value = cfg.sender_email || '';
            document.getElementById('smtp-password').value = cfg.sender_password || '';
            document.getElementById('smtp-provider').value = 'custom';
            
            const s = (cfg.smtp_server || '').toLowerCase();
            if (s.includes('naver')) document.getElementById('smtp-provider').value = 'naver';
            else if (s.includes('gmail')) document.getElementById('smtp-provider').value = 'gmail';
            else if (s.includes('kakao')) document.getElementById('smtp-provider').value = 'kakao';
            else if (s.includes('daum')) document.getElementById('smtp-provider').value = 'hanmail';
            else if (s.includes('nate')) document.getElementById('smtp-provider').value = 'nate';

            document.getElementById('smtp-modal').style.display = 'flex';
        }

        async function deleteSmtp(id) {
            if(!confirm('?씠 SMTP ?꽕?젙?쓣 ?궘?젣?븯?떆寃좎뒿?땲源??')) return;
            const data = await fetchAPI(`/api/v3/email-setup/${id}`, { method: 'DELETE' });
            if (data.success) {
                alert('?꽕?젙?씠 ?궘?젣?릺?뿀?뒿?땲?떎.');
                loadSmtpConfigs();
            } else {
                alert('?궘?젣 ?떎?뙣: ' + data.message);
            }
        }

        async function saveNewCompany() {
            const payload = {
                company_name: document.getElementById('add-company-name').value,
                biz_no: document.getElementById('add-biz-no').value,
                representative_name: document.getElementById('add-representative-name').value,
                region: document.getElementById('add-region').value,
                email: document.getElementById('add-email').value,
                category: document.querySelector('input[name="add-category"]:checked').value
            };
            const data = await fetchAPI('/api/email/companies/add', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(payload) });
            if (data.success) { alert("?쁺援? ????옣?릺?뿀?뒿?땲?떎."); closeCorpAddModal(); loadCompanies(); }
            else alert("????옣 ?떎?뙣: " + data.message);
        }

        async function saveSmtpConfig() {
            const config = {
                config_id: document.getElementById('smtp-id').value || null,
                config_name: document.getElementById('smtp-name').value,
                smtp_server: document.getElementById('smtp-server').value,
                smtp_port: parseInt(document.getElementById('smtp-port').value),
                sender_email: document.getElementById('smtp-email').value,
                sender_password: document.getElementById('smtp-password').value
            };
            const data = await fetchAPI('/api/v3/email-setup', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(config)
            });
            if (data.success) { alert("?끂?뱶媛? ?솢?꽦?솕?릺?뿀?뒿?땲?떎."); closeSmtpModal(); loadSmtpConfigs(); }
            else alert("援ъ꽦 ?떎?뙣: " + data.message);
        }

        // --- 諛쒖넚 ?쁽?솴(result) ?꺆 濡쒖쭅 ---
        async function loadDispatchStats() {
            const data = await fetchAPI('/api/email/batches');
            const listResult = document.getElementById('dispatch-stats-list');
            const listHistory = document.getElementById('batch-list');
            
            if (!data.success || data.batches.length === 0) {
                const emptyRow = '<tr><td colspan="11" style="text-align:center; color:var(--text-secondary); padding:40px;">議고쉶?맂 諛쒖넚 ?씠?젰?씠 ?뾾?뒿?땲?떎.</td></tr>';
                if(listResult) listResult.innerHTML = emptyRow;
                if(listHistory) listHistory.innerHTML = emptyRow;
                ['stat-total-batches','stat-total-sent','stat-total-success','stat-total-fail'].forEach(id => {
                    const el = document.getElementById(id);
                    if(el) el.textContent = '0';
                });
                return;
            }

            // ?넻怨? 吏묎퀎
            let totalBatches = data.batches.length;
            let totalSent = 0, totalSuccess = 0, totalFail = 0;
            data.batches.forEach(b => {
                totalSent    += (b.total_count    || 0);
                totalSuccess += (b.success_count  || 0);
                totalFail    += (b.fail_count     || 0);
            });

            if(document.getElementById('stat-total-batches')) document.getElementById('stat-total-batches').textContent = totalBatches.toLocaleString();
            if(document.getElementById('stat-total-sent')) document.getElementById('stat-total-sent').textContent    = totalSent.toLocaleString();
            if(document.getElementById('stat-total-success')) document.getElementById('stat-total-success').textContent = totalSuccess.toLocaleString();
            if(document.getElementById('stat-total-fail')) document.getElementById('stat-total-fail').textContent    = totalFail.toLocaleString();

            const rowsHtml = data.batches.map(b => {
                const total   = b.total_count   || 0;
                const sent    = b.sent_count    || 0;
                const succ    = b.success_count || 0;
                const fail    = b.fail_count    || 0;
                const rawDt   = b.sent_at || b.created_at || '';
                const rate    = total > 0 ? Math.round((succ / total) * 100) : 0;
                const rateColor = rate >= 80 ? '#4ade80' : rate >= 50 ? '#fbbf24' : '#f87171';
                
                const batchIdStr = (b.batch_id || b.id || '').toString();
                const sendDate = rawDt.split(' ')[0];
                const displayTime = rawDt.includes(' ') ? rawDt.split(' ')[1].substring(0, 5) : ''; // HH:mm 留? ?몴?떆
                const cleanTitle = (b.subject || b.group_name || '').toLowerCase();

                return `
                <tr class="batch-data-row" data-id="${batchIdStr}" data-title="${cleanTitle}" data-date="${sendDate}" style="height: 60px;">
                    <td style="width:40px; text-align:center; vertical-align:middle;">
                        <input type="checkbox" class="batch-check-item member-checkbox" value="${b.batch_id || b.id}">
                    </td>
                    <td style="width:90px; vertical-align:middle; font-family:Orbitron; font-size:0.65rem; color:var(--neon-cyan); white-space:nowrap; overflow:hidden;">#${batchIdStr.substring(0,8)}</td>
                    <td style="vertical-align:middle; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="${b.subject || b.group_name}">${b.subject || b.group_name || '-'}</td>
                    <td style="width:55px; text-align:center; vertical-align:middle;">${total}</td>
                    <td style="width:55px; text-align:center; vertical-align:middle; color:var(--neon-blue);">${sent}</td>
                    <td style="width:55px; text-align:center; vertical-align:middle; color:#4ade80;">${succ}</td>
                    <td style="width:55px; text-align:center; vertical-align:middle; color:#f87171;">${fail}</td>
                    <td style="width:65px; text-align:center; vertical-align:middle;">
                        <span style="color:${rateColor}; font-weight:800; font-size:0.8rem;">${rate}%</span>
                    </td>
                    <td style="width:140px; vertical-align:middle; font-size:0.75rem; color:var(--text-secondary); white-space:nowrap; overflow:hidden;">
                        ${sendDate} <span style="opacity:0.6; font-size:0.65rem; margin-left:2px;">${displayTime}</span>
                    </td>
                    <td style="width:95px; text-align:center; vertical-align:middle; white-space:nowrap;">${formatStatusBadge(b.status)}</td>
                    <td style="width:85px; text-align:center; vertical-align:middle;">
                        <button class="btn btn-outline" style="padding:4px 8px; font-size:0.65rem; font-family:Orbitron;" onclick="viewResultDetail('${b.batch_id || b.id}', '${(b.subject||b.group_name||'').substring(0,20)}')">
                            <i class="fas fa-list-ul"></i> LOG
                        </button>
                    </td>
                </tr>`;
            }).join('');

            if(listHistory) listHistory.innerHTML = rowsHtml;
            if(listResult) listResult.innerHTML = rowsHtml;
        }

        // --- 諛곗튂/濡쒓렇 ?젙由? ?젣?뼱 ?븿?닔 ---
        function toggleBatchChecks(master, listId) {
            const checks = document.getElementById(listId).querySelectorAll('.batch-check-item');
            checks.forEach(c => c.checked = master.checked);
        }

        function filterHistoryTable() {
            const key = (document.getElementById('search-history-key').value || '').toLowerCase();
            const date = document.getElementById('search-history-date').value;
            const rows = document.querySelectorAll('#batch-list .batch-data-row');
            applyBatchFilter(rows, key, date);
        }

        function filterResultTable() {
            const key = (document.getElementById('search-result-key').value || '').toLowerCase();
            const date = document.getElementById('search-result-date').value;
            const rows = document.querySelectorAll('#dispatch-stats-list .batch-data-row');
            applyBatchFilter(rows, key, date);
        }

        function applyBatchFilter(rows, key, date) {
            rows.forEach(r => {
                const bId = r.getAttribute('data-id');
                const bTitle = r.getAttribute('data-title');
                const bDate = r.getAttribute('data-date');
                
                const matchKey = !key || bId.includes(key) || bTitle.includes(key);
                const matchDate = !date || bDate === date;
                
                r.style.display = (matchKey && matchDate) ? '' : 'none';
            });
        }

        function resetHistoryFilter() {
            document.getElementById('search-history-key').value = '';
            document.getElementById('search-history-date').value = '';
            filterHistoryTable();
        }

        function resetResultFilter() {
            document.getElementById('search-result-key').value = '';
            document.getElementById('search-result-date').value = '';
            filterResultTable();
        }

        async function deleteSelectedBatches(type) {
            const listId = type === 'history' ? 'batch-list' : 'dispatch-stats-list';
            const selected = Array.from(document.getElementById(listId).querySelectorAll('.batch-check-item:checked')).map(c => c.value);
            
            if (selected.length === 0) { alert('?젙由ы븷 ?빆紐⑹쓣 1媛? ?씠?긽 ?꽑?깮?빐二쇱꽭?슂.'); return; }
            if (!confirm(`?꽑?깮?븳 ${selected.length}媛쒖쓽 諛쒖넚 ?씠?젰?쓣 ?쁺援? ?궘?젣?븯?떆寃좎뒿?땲源??\n?씠 ?뜲?씠?꽣?뒗 蹂듦뎄?븷 ?닔 ?뾾?뒿?땲?떎.`)) return;

            const res = await fetch('/api/email/delete-batches', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ batch_ids: selected })
            });
            const data = await res.json();
            if (data.success) {
                alert(`${data.count}媛쒖쓽 濡쒓렇媛? ?꽦怨듭쟻?쑝濡? ?젙由щ릺?뿀?뒿?땲?떎.`);
                loadDispatchStats(); // ?쟾泥? ?뜲?씠?꽣 ?깉濡쒓퀬移?
            } else {
                alert('?젙由? ?떎?뙣: ' + data.message);
            }
        }

        async function viewResultDetail(batchId, label) {
            const data = await fetchAPI(`/api/email/batch-details/${batchId}`);
            const area = document.getElementById('result-detail-area');
            const detailList = document.getElementById('result-detail-list');
            document.getElementById('result-detail-title').innerHTML = `<i class="fas fa-list" style="margin-right:10px;"></i>${label} ??? ?긽?꽭 諛쒖넚 濡쒓렇`;
            area.style.display = 'block';

            if (!data.success || data.details.length === 0) {
                detailList.innerHTML = '<tr><td colspan="5" style="text-align:center; color:var(--text-secondary); padding:30px;">?긽?꽭 濡쒓렇媛? ?뾾?뒿?땲?떎.</td></tr>';
            } else {
                detailList.innerHTML = data.details.map(d => {
                    const st = (d.status || '').toUpperCase();
                    const isSuccess = st === 'SUCCESS';
                    const isFail = st === 'FAIL' || st === 'ERROR' || st === 'FAILED';
                    const dt = d.sent_at || d.created_at || '';
                    return `
                    <tr>
                        <td>${d.company_name || '-'}</td>
                        <td style="color:var(--neon-blue); font-size:0.85rem;">${d.email || '-'}</td>
                        <td style="font-size:0.75rem; white-space:nowrap;">${formatDateTime(dt)}</td>
                        <td>${formatStatusBadge(d.status)}</td>
                        <td style="font-size:0.7rem; color:${isFail?'#f87171':'var(--text-secondary)'}; max-width:280px;">${d.error_msg || d.error_message || (isSuccess ? '?젙?긽 諛쒖넚 ?셿猷?' : '-')}</td>
                    </tr>`;
                }).join('');
            }
            area.scrollIntoView({ behavior: 'smooth' });
        }

        // --- 諛섏넚 硫붿씪 ?뒪罹? ---
        async function initBounceSmtpSelect() {
            // SMTP ?꽕?젙 紐⑸줉?쓣 bounce-smtp-select?뿉 梨꾩썙?꽔湲?
            const sel = document.getElementById('bounce-smtp-select');
            if (!sel) return;
            try {
                const data = await fetchAPI('/api/v3/email-setup');
                if (data.success && data.configs && data.configs.length > 0) {
                    data.configs.forEach(cfg => {
                        const opt = document.createElement('option');
                        opt.value = cfg.config_id;
                        opt.textContent = `${cfg.config_name} (${cfg.sender_email})`;
                        sel.appendChild(opt);
                    });
                    // 湲곕낯媛?: ?삤?뒛 ?궇吏?
                    const d = new Date();
                    document.getElementById('bounce-since-date').value =
                        d.toISOString().substring(0, 10);
                }
            } catch(e) { console.warn('SMTP 紐⑸줉 濡쒕뱶 ?떎?뙣:', e); }
        }

        async function checkBounces() {
            const smtpId   = document.getElementById('bounce-smtp-select').value;
            const sinceDate = document.getElementById('bounce-since-date').value;

            if (!smtpId) { alert('SMTP 怨꾩젙?쓣 ?꽑?깮?빐二쇱꽭?슂.'); return; }
            if (!sinceDate) { alert('寃??궗 ?떆?옉 ?궇吏쒕?? ?꽑?깮?빐二쇱꽭?슂.'); return; }

            const btn = document.getElementById('btn-check-bounces');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> &nbsp;IMAP ?뒪罹? 以?... (理쒕?? 30珥? ?냼?슂)';

            const resultArea   = document.getElementById('bounce-result-area');
            const noResultArea = document.getElementById('bounce-no-result');
            resultArea.style.display = 'none';

            try {
                const data = await fetchAPI('/api/email/check-bounces', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ smtp_config_id: parseInt(smtpId), since_date: sinceDate })
                });

                noResultArea.style.display = 'none';
                resultArea.style.display   = 'block';

                const summary = document.getElementById('bounce-result-summary');
                const emailList = document.getElementById('bounce-email-list');

                if (data.success) {
                    if (data.bounced_count === 0) {
                        summary.innerHTML = `<i class="fas fa-check-circle" style="color:#4ade80; margin-right:8px;"></i>諛섏넚 硫붿씪 ?뾾?쓬 ??? 紐⑤몢 ?젙?긽 ?쟾?떖`;
                        emailList.innerHTML = `<span style="color:var(--text-secondary);">諛쏆???렪吏??븿?뿉 諛섏넚 硫붿씪?씠 媛먯???릺吏? ?븡?븯?뒿?땲?떎.</span>`;
                    } else {
                        summary.innerHTML = `
                            <i class="fas fa-exclamation-triangle" style="color:#f87171; margin-right:8px;"></i>
                            諛섏넚 <strong style="color:#f87171;">${data.bounced_count}嫄?</strong> 媛먯?? ???
                            濡쒓렇 <strong>${data.updated_log_count}嫄?</strong> BOUNCE 泥섎━ ?셿猷?<br>
                            <span style="font-size:0.75rem; color:var(--text-secondary); font-weight:400;">
                                ?빐?떦 湲곗뾽??? ???寃? 洹몃９ ?옱?깮?꽦 ?떆 ?옄?룞 ?젣?쇅?맗?땲?떎.
                            </span>`;
                        emailList.innerHTML = (data.bounced_emails || []).map(addr =>
                            `<div>?윋? ${addr}</div>`
                        ).join('');
                        // 諛쒖넚 ?쁽?솴 ?꺆 媛깆떊
                        loadDispatchStats();
                    }
                } else {
                    summary.innerHTML = `<i class="fas fa-times-circle" style="color:#f87171; margin-right:8px;"></i>?뒪罹? ?떎?뙣`;
                    emailList.innerHTML = `<span style="color:#f87171;">${data.message || '?븣 ?닔 ?뾾?뒗 ?삤瑜?'}</span>`;
                }
            } catch(e) {
                noResultArea.style.display = 'none';
                resultArea.style.display   = 'block';
                document.getElementById('bounce-result-summary').innerHTML =
                    `<i class="fas fa-times-circle" style="color:#f87171;"></i> ?꽕?듃?썙?겕 ?삤瑜?`;
                document.getElementById('bounce-email-list').textContent = e.toString();
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-search"></i> &nbsp;諛섏넚 硫붿씪 ?뒪罹? &amp; ?뾽?뜲?씠?듃';
            }
        }

        async function repairCategories() {
            if(!confirm("誘몃텇瑜섎맂 紐⑤뱺 ?뜲?씠?꽣瑜? '?씪諛섎???긽'?쑝濡? 蹂듦뎄?븯?떆寃좎뒿?땲源?? (?씠 ?옉?뾽??? ?닔 珥덇?? ?냼?슂?맆 ?닔 ?엳?뒿?땲?떎)")) return;
            
            const data = await fetchAPI('/api/v3/repair-categories', { method: 'POST' });
            
            if (data.success) {
                alert(data.message);
                loadCompanies();
            } else {
                alert("蹂듦뎄 ?떎?뙣: " + data.message);
            }
        }

        // 珥덇린?솕
        window.onload = () => {
            showTab('setup');
            loadTargetGroups();
            initBounceSmtpSelect();
        };

        function updateFileNameDisplay() {
            const input = document.getElementById('bulk-result-file');
            const fileNameDisp = document.getElementById('selected-file-name');
            if (input.files[0]) {
                fileNameDisp.innerHTML = `<i class="fas fa-file-csv" style="color:#fff;"></i> ${input.files[0].name}`;
                fileNameDisp.style.color = 'var(--neon-cyan)';
            }
        }

        async function excludeFailedEmails(event, groupId) {
            event.stopPropagation();
            if (!confirm('?떎?뙣?맂 ?씠硫붿씪?쓣 洹몃９?뿉?꽌 ?젣?쇅?븯?떆寃좎뒿?땲源?? ?씠 ?옉?뾽??? ?닔 ?뾾?뒿?땲?떎.')) return;
            
            const data = await fetchAPI(`/api/email/exclude-failed/${groupId}`, { method: 'POST' });
            if (data.success) {
                alert(`${data.removed_count}媛? ?떎?뙣 ?씠硫붿씪?쓣 ?젣?쇅?뿀?뒿?땲?떎.`);
                loadTargetGroups(); // ?떎?뙣 ?젣?쇅 ?썑 ?깉濡쒓퀬移?
            } else {
                alert('?젣?쇅 ?떎?뙣: ' + data.message);
            }
        }

        async function uploadBulkResults() {
            const input = document.getElementById('bulk-result-file');
            if (!input.files[0]) { alert('諛섏쁺?븷 CSV ?뙆?씪?쓣 ?꽑?깮?빐二쇱꽭?슂.'); return; }

            const btn = document.getElementById('btn-upload-bulk');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 諛섏쁺 以?...';

            const formData = new FormData();
            formData.append('file', input.files[0]);

            try {
                const response = await fetch('/api/email/upload-bulk-results', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();

                if (data.success) {
                    alert(`${data.count}媛? 湲곗뾽?쓽 諛쒖넚 寃곌낵媛? ?떆?뒪?뀥?뿉 諛섏쁺?릺?뿀?뒿?땲?떎.`);
                    input.value = '';
                    document.getElementById('selected-file-name').textContent = 'CSV ?뙆?씪?쓣 ?꽑?깮?븯嫄곕굹 ?뿬湲곕줈 ?뱶?옒洹명븯?꽭?슂';
                    document.getElementById('selected-file-name').style.color = 'var(--text-secondary)';
                    loadDispatchStats(); // ?넻怨? 媛깆떊
                } else {
                    alert('諛섏쁺 ?떎?뙣: ' + data.message);
                }
            } catch (e) {
                alert('?꽕?듃?썙?겕 ?삤瑜?: ' + e.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }
    </script>
    
    <!-- Floating Scroll Buttons -->
    <div style="position: fixed; bottom: 40px; right: 40px; display: flex; flex-direction: column; gap: 15px; z-index: 9999;">
        <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); color: #fff; width: 50px; height: 50px; border-radius: 25px; cursor: pointer; backdrop-filter: blur(5px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); transition: 0.3s; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;" onmouseover="this.style.background='rgba(0, 212, 255, 0.3)'" onmouseout="this.style.background='rgba(255, 255, 255, 0.1)'"><i class="fas fa-arrow-up"></i></button>
        <button onclick="window.scrollTo({top: document.body.scrollHeight, behavior: 'smooth'})" style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); color: #fff; width: 50px; height: 50px; border-radius: 25px; cursor: pointer; backdrop-filter: blur(5px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); transition: 0.3s; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;" onmouseover="this.style.background='rgba(0, 212, 255, 0.3)'" onmouseout="this.style.background='rgba(255, 255, 255, 0.1)'"><i class="fas fa-arrow-down"></i></button>
    </div>
</body>
</html>
