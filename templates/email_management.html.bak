                        <input type="date" id="search-history-date" onchange="filterHistoryTable()" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #fff; padding: 9px; width: 100%; font-size: 0.85rem;">
                    </div>
