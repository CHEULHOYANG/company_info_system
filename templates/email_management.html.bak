                        <input type="text" id="search-history-key" placeholder="議고쉶 ?궎?썙?뱶 ?엯?젰..." onkeyup="if(event.key==='Enter') filterHistoryTable()" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #fff; padding: 10px; width: 100%; font-size: 0.85rem;">
                    </div>
